{
  "name": "shutterclose",
  "version": "0.1.0",
  "description": "Animated roller-shutter effect for any HTML element — zero dependencies, 1.6 KB gzip, React & Vue included",
  "keywords": [
    "animation",
    "shutter",
    "roller-shutter",
    "overlay",
    "transition",
    "effect",
    "closed-sign",
    "maintenance",
    "modal",
    "typescript",
    "zero-dependency",
    "react",
    "vue",
    "vanilla",
    "esm",
    "css-animation"
  ],
  "author": {
    "name": "alew140",
    "url": "https://github.com/alew140"
  },
  "license": "MIT",
  "homepage": "https://github.com/alew140/shutterclose#readme",
  "bugs": {
    "url": "https://github.com/alew140/shutterclose/issues"
  },
  "engines": {
    "node": ">=16"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/alew140/shutterclose"
  },
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    },
    "./react": {
      "types": "./dist/react/index.d.ts",
      "import": "./dist/react/index.mjs",
      "require": "./dist/react/index.js"
    },
    "./vue": {
      "types": "./dist/vue/index.d.ts",
      "import": "./dist/vue/index.mjs",
      "require": "./dist/vue/index.js"
    },
    "./no-css": {
      "types": "./dist/no-css.d.ts",
      "import": "./dist/no-css.mjs",
      "require": "./dist/no-css.js"
    },
    "./shutterclose.css": "./dist/shutterclose.css"
  },
  "sideEffects": [
    "./dist/index.mjs",
    "./dist/index.js",
    "./dist/react/index.mjs",
    "./dist/react/index.js",
    "./dist/shutterclose.css"
  ],
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "type-check": "tsc --noEmit",
    "prepublishOnly": "npm run type-check && npm run test && npm run build",
    "release": "changeset publish"
  },
  "peerDependencies": {
    "react": ">=18",
    "vue": ">=3"
  },
  "peerDependenciesMeta": {
    "react": {
      "optional": true
    },
    "vue": {
      "optional": true
    }
  },
  "devDependencies": {
    "@changesets/cli": "^2.27.0",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/react": "^16.0.0",
    "@testing-library/user-event": "^14.0.0",
    "@types/react": "^18.0.0",
    "@vitejs/plugin-vue": "^6.0.7",
    "@vitest/coverage-v8": "^4.1.8",
    "@vue/test-utils": "^2.4.0",
    "happy-dom": "^20.10.2",
    "react": "^18.3.0",
    "react-dom": "^18.3.0",
    "tsup": "^8.3.0",
    "typescript": "^5.6.0",
    "vitest": "^4.1.8",
    "vue": "^3.5.0"
  }
}
